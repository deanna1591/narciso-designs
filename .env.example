# Copy this file to ".env" for local dev, and set the same values
# in Vercel → Project → Settings → Environment Variables.

# ---- Front-end (PUBLIC, safe to expose). From Supabase → Settings → API ----
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# ---- Server-only (SECRET, never prefixed with VITE_). For /api/anthropic ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
